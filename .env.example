# Copiar a .env y completar (el archivo .env no se sube a git)

# Usuario SuperAdmin inicial (solo se crea si ese username no existe en la BD)
ANDES_ADMIN_USERNAME=admin
ANDES_ADMIN_PASSWORD=1234
ANDES_ADMIN_EMAIL=admin@andesautoparts.cl

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=tu_cuenta@gmail.com
MAIL_PASSWORD=contraseña_de_aplicacion_gmail
MAIL_FROM=tu_cuenta@gmail.com

# SII Sync — consulta DTE emitidos vía API intermediaria (no emisión desde ERP)
SII_API_PROVIDER=baseapi
SII_API_KEY=
SII_RUT_EMPRESA=
SII_RUT=
SII_PASSWORD=
SII_AMBIENTE=certificacion
