# Copiar a .env y completar (el archivo .env no se sube a git)

# Google Cloud Vision — OCR de facturas en ingreso de bodega
GOOGLE_VISION_CREDENTIALS=data/google_service_account.json

# Cloudinary — imágenes de productos en la nube
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Usuario SuperAdmin inicial (solo si no hay ningún SuperAdmin en la BD)
ANDES_ADMIN_USERNAME=admin
ANDES_ADMIN_PASSWORD=
ANDES_ADMIN_EMAIL=admin@andesautoparts.cl

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=tu_cuenta@gmail.com
MAIL_PASSWORD=contraseña_de_aplicacion_gmail
MAIL_FROM=tu_cuenta@gmail.com

# SII Sync — consulta DTE emitidos vía API intermediaria (no emisión desde ERP)
SII_API_PROVIDER=baseapi
SII_API_KEY=
SII_RUT_EMPRESA=
SII_RUT=
SII_PASSWORD=
SII_AMBIENTE=certificacion

# Google Drive — backup automático de base de datos
GDRIVE_OAUTH_CREDENTIALS=
GDRIVE_TOKEN_PATH=
GDRIVE_FOLDER_ID=1XxoL6h2lpQ26_-RXiqe1hWVamOtz3JHD
BACKUP_RETENTION_DAYS=
